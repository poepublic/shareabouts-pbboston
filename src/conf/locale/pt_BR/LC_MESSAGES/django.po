#: src/flavors/cycle1/_config.translations.py:8
#: src/flavors/cycle2/_config.translations.py:8
#: src/flavors/cycle3/_config.translations.py:8
msgid ""
"Shareabouts is a mapping tool to gather crowd sourced public input. Use it "
"to collect suggested locations and comments in a social, engaging process."
msgstr ""
"Shareabouts é uma ferramenta de mapeamento para coletar informações públicas "
"de crowdsourcing. Use-a para coletar sugestões de locais e comentários em um "
"processo social e envolvente."

#: src/flavors/cycle1/_config.translations.py:9
#: src/flavors/cycle2/_config.translations.py:9
#: src/flavors/cycle3/_config.translations.py:9
msgid "Enter a location…"
msgstr "Insira um local…"

#: src/flavors/cycle1/_config.translations.py:10
#: src/flavors/cycle1/_config.translations.py:62
#: src/flavors/cycle1/_config.translations.py:113
#: src/flavors/cycle2/_config.translations.py:10
#: src/flavors/cycle2/_config.translations.py:66
#: src/flavors/cycle2/_config.translations.py:145
#: src/flavors/cycle3/_config.translations.py:10
#: src/flavors/cycle3/_config.translations.py:67
msgid "Arts & Culture"
msgstr "Artes e Cultura"

#: src/flavors/cycle1/_config.translations.py:11
#: src/flavors/cycle2/_config.translations.py:11
#: src/flavors/cycle3/_config.translations.py:11
msgid ""
"Project ideas focused on arts and cultural programming that promote cultural "
"spaces in the City."
msgstr ""
"Ideias de projetos focadas em programação artística e cultural que promovam "
"espaços culturais na Cidade."

#: src/flavors/cycle1/_config.translations.py:12
#: src/flavors/cycle1/_config.translations.py:63
#: src/flavors/cycle1/_config.translations.py:114
#: src/flavors/cycle2/_config.translations.py:12
#: src/flavors/cycle2/_config.translations.py:67
#: src/flavors/cycle2/_config.translations.py:146
#: src/flavors/cycle3/_config.translations.py:12
#: src/flavors/cycle3/_config.translations.py:68
msgid "Community Resources"
msgstr "Recursos da Comunidade"

#: src/flavors/cycle1/_config.translations.py:13
#: src/flavors/cycle2/_config.translations.py:13
#: src/flavors/cycle3/_config.translations.py:13
msgid ""
"Project ideas that provide assistance or services to residents in need, such "
"as programs at community centers, financial or digital literacy, English as "
"a second language, or GED classes."
msgstr ""
"Ideias de projetos que ofereçam assistência ou serviços a moradores "
"necessitados, como programas em centros comunitários, educação financeira ou "
"digital, inglês como segunda língua ou aulas de GED."

#: src/flavors/cycle1/_config.translations.py:14
#: src/flavors/cycle1/_config.translations.py:64
#: src/flavors/cycle1/_config.translations.py:115
#: src/flavors/cycle2/_config.translations.py:14
#: src/flavors/cycle2/_config.translations.py:68
#: src/flavors/cycle2/_config.translations.py:147
#: src/flavors/cycle3/_config.translations.py:14
#: src/flavors/cycle3/_config.translations.py:69
msgid "Local Economy & Worker Empowerment"
msgstr "Economia Local e Empoderamento dos Trabalhadores"

#: src/flavors/cycle1/_config.translations.py:15
#: src/flavors/cycle2/_config.translations.py:15
#: src/flavors/cycle3/_config.translations.py:15
msgid ""
"Project ideas that improve access to quality jobs, skills training, career "
"pipelines, and other resources for workers, small business owners, and "
"entrepreneurs."
msgstr ""
"Ideias de projetos que melhoram o acesso a empregos de qualidade, "
"treinamento de habilidades, planos de carreira e outros recursos para "
"trabalhadores, proprietários de pequenas empresas e empreendedores."

#: src/flavors/cycle1/_config.translations.py:16
#: src/flavors/cycle1/_config.translations.py:65
#: src/flavors/cycle1/_config.translations.py:116
msgid "Education, Youth & Families"
msgstr "Educação, Juventude e Famílias"

#: src/flavors/cycle1/_config.translations.py:17
#: src/flavors/cycle2/_config.translations.py:17
#: src/flavors/cycle3/_config.translations.py:17
msgid ""
"Project ideas related to education for all ages, as well as proposals that "
"meet the needs of Boston’s youth, senior citizens, and families."
msgstr ""
"Ideias de projetos relacionados à educação para todas as idades, bem como "
"propostas que atendam às necessidades dos jovens, idosos e famílias de "
"Boston."

#: src/flavors/cycle1/_config.translations.py:18
#: src/flavors/cycle1/_config.translations.py:66
#: src/flavors/cycle1/_config.translations.py:117
#: src/flavors/cycle2/_config.translations.py:18
#: src/flavors/cycle2/_config.translations.py:70
#: src/flavors/cycle2/_config.translations.py:149
#: src/flavors/cycle3/_config.translations.py:18
#: src/flavors/cycle3/_config.translations.py:71
msgid "Environment, Sustainability, and Food Access"
msgstr "Meio Ambiente, Sustentabilidade e Acesso a Alimentos"

#: src/flavors/cycle1/_config.translations.py:19
#: src/flavors/cycle2/_config.translations.py:19
#: src/flavors/cycle3/_config.translations.py:19
msgid ""
"Project ideas that help increase access to healthy and affordable food, "
"promote environmental justice, and help increase the quality of life in "
"Boston."
msgstr ""
"Ideias de projetos que ajudem a aumentar o acesso a alimentos saudáveis e "
"acessíveis, promovam a justiça ambiental e ajudem a melhorar a qualidade de "
"vida em Boston."

#: src/flavors/cycle1/_config.translations.py:20
#: src/flavors/cycle2/_config.translations.py:20
#: src/flavors/cycle3/_config.translations.py:20
msgid "Facilities, Parks & Recreation"
msgstr "Instalações, Parques e Recreação"

#: src/flavors/cycle1/_config.translations.py:21
#: src/flavors/cycle2/_config.translations.py:21
#: src/flavors/cycle3/_config.translations.py:21
msgid ""
"Project ideas that Invest in clean, green, safe and accessible open space, "
"facilities, and programming for residents and neighborhoods."
msgstr ""
"Ideias de projetos que investem em espaços abertos, instalações e programas "
"limpos, verdes, seguros e acessíveis para moradores e bairros."

#: src/flavors/cycle1/_config.translations.py:22
#: src/flavors/cycle1/_config.translations.py:68
#: src/flavors/cycle1/_config.translations.py:119
#: src/flavors/cycle2/_config.translations.py:22
#: src/flavors/cycle2/_config.translations.py:72
#: src/flavors/cycle2/_config.translations.py:151
#: src/flavors/cycle3/_config.translations.py:22
#: src/flavors/cycle3/_config.translations.py:73
msgid "Health & Well-being"
msgstr "Saúde e bem-estar"

#: src/flavors/cycle1/_config.translations.py:23
#: src/flavors/cycle2/_config.translations.py:23
#: src/flavors/cycle3/_config.translations.py:23
msgid ""
"Project ideas that promote the physical and mental health of Boston "
"residents of all ages."
msgstr ""
"Ideias de projetos que promovam a saúde física e mental dos moradores de "
"Boston de todas as idades."

#: src/flavors/cycle1/_config.translations.py:24
#: src/flavors/cycle1/_config.translations.py:69
#: src/flavors/cycle1/_config.translations.py:120
#: src/flavors/cycle2/_config.translations.py:24
#: src/flavors/cycle2/_config.translations.py:73
#: src/flavors/cycle2/_config.translations.py:152
#: src/flavors/cycle3/_config.translations.py:24
#: src/flavors/cycle3/_config.translations.py:74
msgid "Public Safety"
msgstr "Segurança Pública"

#: src/flavors/cycle1/_config.translations.py:25
#: src/flavors/cycle2/_config.translations.py:25
#: src/flavors/cycle3/_config.translations.py:25
msgid ""
"Project ideas that advance safety and increase justice in the City, such as "
"community violence prevention programs and initiatives for healing and "
"recovering from trauma and substance abuse."
msgstr ""
"Ideias de projetos que promovam a segurança e aumentem a justiça na cidade, "
"como programas de prevenção à violência comunitária e iniciativas para cura "
"e recuperação de traumas e abuso de substâncias."

#: src/flavors/cycle1/_config.translations.py:26
#: src/flavors/cycle1/_config.translations.py:70
#: src/flavors/cycle1/_config.translations.py:121
#: src/flavors/cycle2/_config.translations.py:26
#: src/flavors/cycle2/_config.translations.py:74
#: src/flavors/cycle2/_config.translations.py:153
#: src/flavors/cycle3/_config.translations.py:26
#: src/flavors/cycle3/_config.translations.py:75
msgid "Streets & Sidewalks"
msgstr "Ruas e calçadas"

#: src/flavors/cycle1/_config.translations.py:27
#: src/flavors/cycle2/_config.translations.py:27
#: src/flavors/cycle3/_config.translations.py:27
msgid ""
"Project ideas to improve City streets and sidewalks and promote safety and "
"accessibility."
msgstr ""
"Ideias de projetos para melhorar as ruas e calçadas da cidade e promover "
"segurança e acessibilidade."

#: src/flavors/cycle1/_config.translations.py:28
#: src/flavors/cycle1/_config.translations.py:71
#: src/flavors/cycle1/_config.translations.py:122
#: src/flavors/cycle2/_config.translations.py:28
#: src/flavors/cycle2/_config.translations.py:75
#: src/flavors/cycle2/_config.translations.py:154
#: src/flavors/cycle3/_config.translations.py:28
#: src/flavors/cycle3/_config.translations.py:76
msgid "Other / Not Sure"
msgstr "Outro / Não tenho certeza"

#: src/flavors/cycle1/_config.translations.py:29
#: src/flavors/cycle2/_config.translations.py:29
#: src/flavors/cycle3/_config.translations.py:29
msgid ""
"Other community centered ideas that may not fit in the previous categories."
msgstr ""
"Outras ideias centradas na comunidade que podem não se enquadrar nas "
"categorias anteriores."

#: src/flavors/cycle1/_config.translations.py:30
#: src/flavors/cycle2/_config.translations.py:30
#: src/flavors/cycle3/_config.translations.py:30
msgid "idea"
msgstr "ideia"

#: src/flavors/cycle1/_config.translations.py:31
#: src/flavors/cycle2/_config.translations.py:31
#: src/flavors/cycle3/_config.translations.py:31
msgid "ideas"
msgstr "ideias"

#: src/flavors/cycle1/_config.translations.py:32
#: src/flavors/cycle1/templates/index.html:57
msgid "Suggest an Idea"
msgstr "Sugira uma ideia"

