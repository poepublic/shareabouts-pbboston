msgstr "社区资源"

#: src/flavors/cycle1/_config.translations.py:13
#: src/flavors/cycle2/_config.translations.py:13
#: src/flavors/cycle3/_config.translations.py:13
msgid ""
"Project ideas that provide assistance or services to residents in need, such"
" as programs at community centers, financial or digital literacy, English as"
" a second language, or GED classes."
msgstr "为有需要的居民提供援助或服务的项目构想，例如社区中心的项目、金融或数字素养、英语作为第二语言或 GED 课程。"

#: src/flavors/cycle1/_config.translations.py:14
#: src/flavors/cycle1/_config.translations.py:64
#: src/flavors/cycle1/_config.translations.py:115
#: src/flavors/cycle2/_config.translations.py:14
#: src/flavors/cycle2/_config.translations.py:68
#: src/flavors/cycle2/_config.translations.py:147
#: src/flavors/cycle3/_config.translations.py:14
#: src/flavors/cycle3/_config.translations.py:69
