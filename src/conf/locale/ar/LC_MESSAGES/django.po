#: src/flavors/cycle1/_config.translations.py:8
#: src/flavors/cycle2/_config.translations.py:8
#: src/flavors/cycle3/_config.translations.py:8
msgid ""
"Shareabouts is a mapping tool to gather crowd sourced public input. Use it "
"to collect suggested locations and comments in a social, engaging process."
msgstr ""
"Shareabouts هي أداة رسم خرائط لجمع المدخلات العامة من مصادر جماعية. استخدمه "
"لجمع المواقع والتعليقات المقترحة في عملية اجتماعية وجذابة."

#: src/flavors/cycle1/_config.translations.py:9
#: src/flavors/cycle2/_config.translations.py:9
#: src/flavors/cycle3/_config.translations.py:9
msgid "Enter a location…"
msgstr "أدخل موقعا..."

#: src/flavors/cycle1/_config.translations.py:10
#: src/flavors/cycle1/_config.translations.py:62
#: src/flavors/cycle1/_config.translations.py:113
#: src/flavors/cycle2/_config.translations.py:10
#: src/flavors/cycle2/_config.translations.py:66
#: src/flavors/cycle2/_config.translations.py:145
#: src/flavors/cycle3/_config.translations.py:10
#: src/flavors/cycle3/_config.translations.py:67
msgid "Arts & Culture"
msgstr "الفنون والثقافة"

#: src/flavors/cycle1/_config.translations.py:11
#: src/flavors/cycle2/_config.translations.py:11
#: src/flavors/cycle3/_config.translations.py:11
msgid ""
"Project ideas focused on arts and cultural programming that promote cultural "
"spaces in the City."
msgstr ""
"تركز أفكار المشاريع على البرامج الفنية والثقافية التي تعزز المساحات الثقافية "
"في المدينة."

#: src/flavors/cycle1/_config.translations.py:12
#: src/flavors/cycle1/_config.translations.py:63
#: src/flavors/cycle1/_config.translations.py:114
#: src/flavors/cycle2/_config.translations.py:12
#: src/flavors/cycle2/_config.translations.py:67
#: src/flavors/cycle2/_config.translations.py:146
#: src/flavors/cycle3/_config.translations.py:12
#: src/flavors/cycle3/_config.translations.py:68
msgid "Community Resources"
msgstr "موارد المجتمع"

#: src/flavors/cycle1/_config.translations.py:13
#: src/flavors/cycle2/_config.translations.py:13
#: src/flavors/cycle3/_config.translations.py:13
msgid ""
"Project ideas that provide assistance or services to residents in need, such "
"as programs at community centers, financial or digital literacy, English as "
"a second language, or GED classes."
msgstr ""
"أفكار المشاريع التي تقدم المساعدة أو الخدمات للمقيمين المحتاجين، مثل البرامج "
"في المراكز المجتمعية، أو محو الأمية المالية أو الرقمية، أو اللغة الإنجليزية "
"كلغة ثانية، أو دروس GED."

#: src/flavors/cycle1/_config.translations.py:14
#: src/flavors/cycle1/_config.translations.py:64
#: src/flavors/cycle1/_config.translations.py:115
#: src/flavors/cycle2/_config.translations.py:14
#: src/flavors/cycle2/_config.translations.py:68
#: src/flavors/cycle2/_config.translations.py:147
#: src/flavors/cycle3/_config.translations.py:14
#: src/flavors/cycle3/_config.translations.py:69
msgid "Local Economy & Worker Empowerment"
msgstr "الاقتصاد المحلي وتمكين العمال"

#: src/flavors/cycle1/_config.translations.py:15
#: src/flavors/cycle2/_config.translations.py:15
#: src/flavors/cycle3/_config.translations.py:15
msgid ""
"Project ideas that improve access to quality jobs, skills training, career "
"pipelines, and other resources for workers, small business owners, and "
"entrepreneurs."
msgstr ""
"أفكار المشاريع التي تعمل على تحسين الوصول إلى وظائف جيدة، والتدريب على "
"المهارات، والمسارات المهنية، وغيرها من الموارد للعمال وأصحاب الأعمال الصغيرة "
"ورجال الأعمال."

#: src/flavors/cycle1/_config.translations.py:16
#: src/flavors/cycle1/_config.translations.py:65
#: src/flavors/cycle1/_config.translations.py:116
msgid "Education, Youth & Families"
msgstr "التعليم والشباب والعائلات"

#: src/flavors/cycle1/_config.translations.py:17
#: src/flavors/cycle2/_config.translations.py:17
#: src/flavors/cycle3/_config.translations.py:17
msgid ""
"Project ideas related to education for all ages, as well as proposals that "
"meet the needs of Boston’s youth, senior citizens, and families."
msgstr ""
"أفكار المشاريع المتعلقة بالتعليم لجميع الأعمار، بالإضافة إلى المقترحات التي "
"تلبي احتياجات شباب بوسطن وكبار السن والعائلات."

#: src/flavors/cycle1/_config.translations.py:18
#: src/flavors/cycle1/_config.translations.py:66
#: src/flavors/cycle1/_config.translations.py:117
#: src/flavors/cycle2/_config.translations.py:18
#: src/flavors/cycle2/_config.translations.py:70
#: src/flavors/cycle2/_config.translations.py:149
#: src/flavors/cycle3/_config.translations.py:18
#: src/flavors/cycle3/_config.translations.py:71
msgid "Environment, Sustainability, and Food Access"
msgstr "البيئة والاستدامة والحصول على الغذاء"

#: src/flavors/cycle1/_config.translations.py:19
#: src/flavors/cycle2/_config.translations.py:19
#: src/flavors/cycle3/_config.translations.py:19
msgid ""
"Project ideas that help increase access to healthy and affordable food, "
"promote environmental justice, and help increase the quality of life in "
"Boston."
msgstr ""
"أفكار المشاريع التي تساعد على زيادة الوصول إلى الغذاء الصحي وبأسعار معقولة، "
"وتعزيز العدالة البيئية، وتساعد على تحسين نوعية الحياة في بوسطن."

#: src/flavors/cycle1/_config.translations.py:20
#: src/flavors/cycle2/_config.translations.py:20
#: src/flavors/cycle3/_config.translations.py:20
msgid "Facilities, Parks & Recreation"
msgstr "المرافق والمتنزهات والترفيه"

#: src/flavors/cycle1/_config.translations.py:21
#: src/flavors/cycle2/_config.translations.py:21
#: src/flavors/cycle3/_config.translations.py:21
msgid ""
"Project ideas that Invest in clean, green, safe and accessible open space, "
"facilities, and programming for residents and neighborhoods."
msgstr ""
"أفكار المشاريع التي تستثمر في المساحات المفتوحة والمرافق والبرمجة النظيفة "
"والخضراء والآمنة والتي يمكن الوصول إليها للمقيمين والأحياء."

#: src/flavors/cycle1/_config.translations.py:22
#: src/flavors/cycle1/_config.translations.py:68
#: src/flavors/cycle1/_config.translations.py:119
#: src/flavors/cycle2/_config.translations.py:22
#: src/flavors/cycle2/_config.translations.py:72
#: src/flavors/cycle2/_config.translations.py:151
#: src/flavors/cycle3/_config.translations.py:22
#: src/flavors/cycle3/_config.translations.py:73
msgid "Health & Well-being"
msgstr "الصحة و أمبير؛ رفاهية"

#: src/flavors/cycle1/_config.translations.py:23
#: src/flavors/cycle2/_config.translations.py:23
#: src/flavors/cycle3/_config.translations.py:23
msgid ""
"Project ideas that promote the physical and mental health of Boston "
"residents of all ages."
msgstr "أفكار مشاريع تعزز الصحة الجسدية والعقلية لسكان بوسطن من جميع الأعمار."

#: src/flavors/cycle1/_config.translations.py:24
#: src/flavors/cycle1/_config.translations.py:69
#: src/flavors/cycle1/_config.translations.py:120
#: src/flavors/cycle2/_config.translations.py:24
#: src/flavors/cycle2/_config.translations.py:73
#: src/flavors/cycle2/_config.translations.py:152
#: src/flavors/cycle3/_config.translations.py:24
#: src/flavors/cycle3/_config.translations.py:74
msgid "Public Safety"
msgstr "السلامة العامة"

#: src/flavors/cycle1/_config.translations.py:25
#: src/flavors/cycle2/_config.translations.py:25
#: src/flavors/cycle3/_config.translations.py:25
msgid ""
"Project ideas that advance safety and increase justice in the City, such as "
"community violence prevention programs and initiatives for healing and "
"recovering from trauma and substance abuse."
msgstr ""
"أفكار المشاريع التي تعمل على تعزيز السلامة وزيادة العدالة في المدينة، مثل "
"برامج الوقاية من العنف المجتمعي ومبادرات الشفاء والتعافي من الصدمات النفسية "
"وتعاطي المخدرات."

#: src/flavors/cycle1/_config.translations.py:26
#: src/flavors/cycle1/_config.translations.py:70
#: src/flavors/cycle1/_config.translations.py:121
#: src/flavors/cycle2/_config.translations.py:26
#: src/flavors/cycle2/_config.translations.py:74
#: src/flavors/cycle2/_config.translations.py:153
#: src/flavors/cycle3/_config.translations.py:26
#: src/flavors/cycle3/_config.translations.py:75
msgid "Streets & Sidewalks"
msgstr "الشوارع والأرصفة"

#: src/flavors/cycle1/_config.translations.py:27
#: src/flavors/cycle2/_config.translations.py:27
#: src/flavors/cycle3/_config.translations.py:27
msgid ""
"Project ideas to improve City streets and sidewalks and promote safety and "
"accessibility."
msgstr ""
"أفكار مشاريع لتحسين شوارع المدينة وأرصفةها وتعزيز السلامة وسهولة الوصول "
"إليها."

#: src/flavors/cycle1/_config.translations.py:28
#: src/flavors/cycle1/_config.translations.py:71
#: src/flavors/cycle1/_config.translations.py:122
#: src/flavors/cycle2/_config.translations.py:28
#: src/flavors/cycle2/_config.translations.py:75
#: src/flavors/cycle2/_config.translations.py:154
#: src/flavors/cycle3/_config.translations.py:28
#: src/flavors/cycle3/_config.translations.py:76
msgid "Other / Not Sure"
msgstr "أخرى / غير متأكد"

#: src/flavors/cycle1/_config.translations.py:29
#: src/flavors/cycle2/_config.translations.py:29
#: src/flavors/cycle3/_config.translations.py:29
msgid ""
"Other community centered ideas that may not fit in the previous categories."
msgstr "أفكار أخرى تتمحور حول المجتمع والتي قد لا تتناسب مع الفئات السابقة."

#: src/flavors/cycle1/_config.translations.py:30
#: src/flavors/cycle2/_config.translations.py:30
#: src/flavors/cycle3/_config.translations.py:30
msgid "idea"
msgstr "فكرة"

#: src/flavors/cycle1/_config.translations.py:31
#: src/flavors/cycle2/_config.translations.py:31
#: src/flavors/cycle3/_config.translations.py:31
msgid "ideas"
msgstr "أفكار"

#: src/flavors/cycle1/_config.translations.py:32
#: src/flavors/cycle1/templates/index.html:57
msgid "Suggest an Idea"
msgstr "أقترح فكرة"

#: src/flavors/cycle1/_config.translations.py:33
#: src/flavors/cycle2/_config.translations.py:33
#: src/flavors/cycle3/_config.translations.py:33
msgid "List All Ideas"
msgstr "قائمة بجميع الأفكار"

#: src/flavors/cycle1/_config.translations.py:34
#: src/flavors/cycle2/_config.translations.py:34
#: src/flavors/cycle3/_config.translations.py:34
msgid "Show the Map"
msgstr "عرض الخريطة"

#: src/flavors/cycle1/_config.translations.py:35
#: src/flavors/cycle2/_config.translations.py:35
#: src/flavors/cycle3/_config.translations.py:35
msgid "submitted"
msgstr "مُقَدَّم"

#: src/flavors/cycle1/_config.translations.py:36
#: src/flavors/cycle2/_config.translations.py:36
#: src/flavors/cycle3/_config.translations.py:36
msgid "How would you spend $2 million to benefit your community?"
msgstr "كيف ستنفق مليوني دولار لإفادة مجتمعك؟"

#: src/flavors/cycle1/_config.translations.py:37
#: src/flavors/cycle2/_config.translations.py:37
#: src/flavors/cycle3/_config.translations.py:37
msgid "Your neighbor"
msgstr "جارك"

#: src/flavors/cycle1/_config.translations.py:38
#: src/flavors/cycle2/_config.translations.py:38
#: src/flavors/cycle3/_config.translations.py:38
msgid "Submit"
msgstr "يُقدِّم"

#: src/flavors/cycle1/_config.translations.py:39
#: src/flavors/cycle2/_config.translations.py:39
msgid "Multiple locations throughout the city"
msgstr "مواقع متعددة في جميع أنحاء المدينة"

#: src/flavors/cycle1/_config.translations.py:40
#: src/flavors/cycle2/_config.translations.py:40
#: src/flavors/cycle3/_config.translations.py:41
msgid "Please use the map's search box or drag the map to set the location."
msgstr "يرجى استخدام مربع البحث الخاص بالخريطة أو سحب الخريطة لتعيين الموقع."

#: src/flavors/cycle1/_config.translations.py:41
#: src/flavors/cycle2/_config.translations.py:41
#: src/flavors/cycle3/_config.translations.py:42
msgid "Thank you!"
msgstr "شكرًا لك!"

#: src/flavors/cycle1/_config.translations.py:42
msgid ""
"Thank you for sharing your idea with us! Please fill out the short form "
"below. Only the information you choose to display will be made public."
msgstr ""
"شكرا لتقاسم فكرتك معنا! يرجى ملء النموذج القصير أدناه. سيتم فقط نشر "
"المعلومات التي تختار عرضها."

#: src/flavors/cycle1/_config.translations.py:43
#: src/flavors/cycle2/_config.translations.py:47
#: src/flavors/cycle3/_config.translations.py:48
msgid "Is your idea for a specific location or for the entire city?"
msgstr "هل فكرتك لمنطقة معينة أم للمدينة بأكملها؟"

#: src/flavors/cycle1/_config.translations.py:44
#: src/flavors/cycle2/_config.translations.py:48
#: src/flavors/cycle3/_config.translations.py:49
msgid "City wide?"
msgstr "على مستوى المدينة؟"

#: src/flavors/cycle1/_config.translations.py:45
#: src/flavors/cycle2/_config.translations.py:49
#: src/flavors/cycle3/_config.translations.py:50
msgid "Location-specific"
msgstr "موقع محدد"

#: src/flavors/cycle1/_config.translations.py:46
#: src/flavors/cycle2/_config.translations.py:50
#: src/flavors/cycle3/_config.translations.py:51
msgid "City-wide"
msgstr "على مستوى المدينة"

#: src/flavors/cycle1/_config.translations.py:47
#: src/flavors/cycle2/_config.translations.py:51
#: src/flavors/cycle3/_config.translations.py:52
msgid "Approximately where would your idea be?"
msgstr "تقريبا أين ستكون فكرتك؟"

#: src/flavors/cycle1/_config.translations.py:48
#: src/flavors/cycle2/_config.translations.py:52
#: src/flavors/cycle3/_config.translations.py:53
msgid "Approximate location…"
msgstr "الموقع التقريبي…"

#: src/flavors/cycle1/_config.translations.py:49
#: src/flavors/cycle2/_config.translations.py:53
#: src/flavors/cycle3/_config.translations.py:54
msgid "Drag the map to set the location."
msgstr "اسحب الخريطة لتعيين الموقع."

#: src/flavors/cycle1/_config.translations.py:50
msgid "Please share a short description of the project idea."
msgstr "يرجى مشاركة وصف مختصر لفكرة المشروع."

#: src/flavors/cycle1/_config.translations.py:51
#: src/flavors/cycle2/_config.translations.py:55
#: src/flavors/cycle3/_config.translations.py:56
msgid "My idea is to…"
msgstr "فكرتي هي…"

#: src/flavors/cycle1/_config.translations.py:52
msgid "Make sure your description is short and clear."
msgstr "تأكد من أن الوصف قصير وواضح."

#: src/flavors/cycle1/_config.translations.py:53
#: src/flavors/cycle1/_config.translations.py:58
#: src/flavors/cycle2/_config.translations.py:57
#: src/flavors/cycle2/_config.translations.py:62
#: src/flavors/cycle3/_config.translations.py:58
#: src/flavors/cycle3/_config.translations.py:63
msgid "Try to keep it to 50 words or less…"
msgstr "حاول أن تجعلها لا تزيد عن 50 كلمة أو أقل..."

#: src/flavors/cycle1/_config.translations.py:54
#: src/flavors/cycle2/_config.translations.py:58
#: src/flavors/cycle3/_config.translations.py:59
msgid "How does your project advance social and racial equity?"
msgstr "كيف يعزز مشروعك العدالة الاجتماعية والعنصرية؟"

#: src/flavors/cycle1/_config.translations.py:55
#: src/flavors/cycle2/_config.translations.py:59
#: src/flavors/cycle3/_config.translations.py:60
msgid "This idea would advance social and racial equity by…"
msgstr "من شأن هذه الفكرة أن تعزز العدالة الاجتماعية والعنصرية من خلال ..."

#: src/flavors/cycle1/_config.translations.py:56
#: src/flavors/cycle2/_config.translations.py:60
#: src/flavors/cycle3/_config.translations.py:61
msgid "Make sure you keep it short and clear."
msgstr "تأكد من إبقائها قصيرة وواضحة."

#: src/flavors/cycle1/_config.translations.py:57
#: src/flavors/cycle2/_config.translations.py:61
#: src/flavors/cycle3/_config.translations.py:62
msgid ""
"\"Social and racial equity\" is defined as the just and fair inclusion of "
"people of any social and racial background into society, so they can "
"participate, prosper, and reach their full potential."
msgstr ""
"يتم تعريف العدالة الاجتماعية والعنصرية على أنها الإدماج العادل والمنصف "
"للأشخاص من أي خلفية اجتماعية أو عنصرية في المجتمع، حتى يتمكنوا من المشاركة "
"والازدهار وتحقيق إمكاناتهم الكاملة."

#: src/flavors/cycle1/_config.translations.py:59
#: src/flavors/cycle2/_config.translations.py:63
#: src/flavors/cycle3/_config.translations.py:64
msgid "Which category does your idea fall into?"
msgstr "في أي فئة تقع فكرتك؟"

#: src/flavors/cycle1/_config.translations.py:60
#: src/flavors/cycle2/_config.translations.py:64
#: src/flavors/cycle3/_config.translations.py:65
msgid "Category"
msgstr "فئة"

#: src/flavors/cycle1/_config.translations.py:61
#: src/flavors/cycle2/_config.translations.py:65
#: src/flavors/cycle3/_config.translations.py:66
msgid "Choose the category that most closely describes your project."
msgstr "اختر الفئة التي تصف مشروعك بشكل وثيق."

#: src/flavors/cycle1/_config.translations.py:67
#: src/flavors/cycle1/_config.translations.py:118
#: src/flavors/cycle2/_config.translations.py:71
#: src/flavors/cycle2/_config.translations.py:150
#: src/flavors/cycle3/_config.translations.py:72
msgid "Facilities, Parks & Recreation  "
msgstr "المرافق والمتنزهات والترفيه  "

#: src/flavors/cycle1/_config.translations.py:72
msgid "Are you submitting this idea as part of a community event?"
msgstr "هل تقدم هذه الفكرة كجزء من حدث مجتمعي؟"

#: src/flavors/cycle1/_config.translations.py:73
msgid "No event; I am submitting this idea on my own"
msgstr "لا حدث؛ أنا أطرح هذه الفكرة بنفسي"

#: src/flavors/cycle1/_config.translations.py:74
msgid ""
"Yes, at an Idea Collection Workshop hosted by an organization sponsored by "
"the Office of Participatory Budgeting"
msgstr ""
"نعم، في ورشة عمل تجميع الأفكار التي تستضيفها منظمة يرعاها مكتب الموازنة "
"التشاركية"

#: src/flavors/cycle1/_config.translations.py:75
msgid "Yes, at an independent community gathering"
msgstr "نعم، في تجمع مجتمعي مستقل"

#: src/flavors/cycle1/_config.translations.py:76
#: src/flavors/cycle1/_config.translations.py:79
msgid "Your Name"
msgstr "اسمك"

#: src/flavors/cycle1/_config.translations.py:77
#: src/flavors/cycle1/_config.translations.py:80
msgid "Submitter's Name"
msgstr "اسم المرسل"

