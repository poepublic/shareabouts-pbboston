msgstr "Ngân sách tham gia của Thành phố Boston"

#: src/flavors/cycle1/_config.translations.py:7
#: src/flavors/cycle1/templates/index.html:8
#: src/flavors/cycle1/templates/index.html:17
#: src/flavors/cycle2/_config.translations.py:7
